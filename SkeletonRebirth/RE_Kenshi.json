{
	"Plugins" : [ "SkeletonRebirthDiagnostics.dll" ],
	"DialogueBoxes" : {
		"system_menu": {
			"title": "System Menu",
			"message": "{name} is in a catastrophic shutdown loop. Any additional actions will require an AI Core. What do you want to do?",
			"buttons": [
				{
					"caption": "Repair",
					"requiresSkill": "science",
					"minSkill": 1,
					"requiresItem": "43392-changes_otto.mod",
					"steps": [
						{ "type": "take_item", "item": "43392-changes_otto.mod" },
						{ "type": "show_text", "text": "Used AI Core", "color": "#FF4C4C" },
						{ "type": "delay", "seconds": 5 },
						{ "type": "show_text", "text": "{name} has been successfully revived!", "color": "#3399FF" },
						{ "type": "action", "action": "reactivate" }
					]
				},
				{
					"caption": "Reset",
					"requiresSkill": "science",
					"minSkill": 1,
					"excludePlayerFaction": true,
					"requiresItem": "43392-changes_otto.mod",
					"steps": [
						{ "type": "take_item", "item": "43392-changes_otto.mod" },
						{ "type": "show_text", "text": "Used AI Core", "color": "#FF4C4C" },
						{ "type": "delay", "seconds": 5 },
						{ "type": "show_text", "text": "{name} has been reset!", "color": "#3399FF" },
						{ "type": "action", "action": "join_squad_fast" },
						{ "type": "action", "action": "system_reset" }
					]
				},
				{
					"caption": "Do nothing",
					"steps": []
				}
			]
		}
	}
}
