{
	"Plugins" : [ "SkeletonRebirthDiagnostics.dll" ],
	"Debug" : true,
	"DialogueTriggers" : [
		{
			"requiredStates" : [ "deactivated", "humanoid", "inBed" ],
			"buildings" : [ "64614-rebirth.mod" ],
			"menu" : "system_menu"
		},
		{
			"requiredStates" : [ "deactivated", "humanoid", "beingRepaired", "repairerScience1" ],
			"buildings" : [],
			"menu" : "system_menu"
		},
		{
			"requiredStates" : [ "deactivated", "animal", "beingRepaired", "repairerScience1" ],
			"buildings" : [],
			"menu" : "system_menu_animal"
		}
	],
	"DialogueBoxes" : {
		"system_menu": {
			"title": "System Menu",
			"item": "43392-changes_otto.mod",
			"message": "{name} is in a catastrophic shutdown loop. Running diagnostics will consume the {item} used - proceed?",
			"buttons": [
				{
					"caption": "Diagnostics",
					"excludeRace": "Skeleton No-Head MkII",
					"requiresSkill": "science",
					"minSkill": 1,
					"requiresItem": "43392-changes_otto.mod",
					"steps": [
						{ "type": "take_item", "item": "43392-changes_otto.mod" },
						{ "type": "show_text", "text": "{item} consumed - running diagnostics...", "item": "43392-changes_otto.mod", "color": "#FF4C4C" },
						{ "type": "delay", "seconds": 3 },
						{ "type": "open_menu", "menu": "diagnostic_menu" }
					]
				},
				{
					"caption": "Diagnostics",
					"requiresRace": "Skeleton No-Head MkII",
					"requiresSkill": "science",
					"minSkill": 1,
					"requiresItem": "43398-changes_otto.mod",
					"steps": [
						{ "type": "take_item", "item": "43398-changes_otto.mod" },
						{ "type": "show_text", "text": "{item} consumed - running diagnostics...", "item": "43398-changes_otto.mod", "color": "#FF4C4C" },
						{ "type": "delay", "seconds": 3 },
						{ "type": "open_menu", "menu": "diagnostic_menu" }
					]
				},
				{
					"caption": "Do nothing",
					"steps": []
				}
			]
		},

		"system_menu_animal": {
			"title": "System Menu",
			"item": "43398-changes_otto.mod",
			"message": "{name} is in a catastrophic shutdown loop. Running diagnostics will consume the {item} used - proceed?",
			"buttons": [
				{
					"caption": "Diagnostics",
					"requiresSkill": "science",
					"minSkill": 1,
					"requiresItem": "43398-changes_otto.mod",
					"steps": [
						{ "type": "take_item", "item": "43398-changes_otto.mod" },
						{ "type": "show_text", "text": "{item} consumed - running diagnostics...", "item": "43398-changes_otto.mod", "color": "#FF4C4C" },
						{ "type": "delay", "seconds": 3 },
						{ "type": "open_menu", "menu": "diagnostic_menu" }
					]
				},
				{
					"caption": "Do nothing",
					"steps": []
				}
			]
		},

		"diagnostic_menu": {
			"title": "Diagnostics",
			"message": "Diagnostics complete. {name}'s core systems are accessible. Select a course of action.",
			"buttons": [
				{
					"caption": "Revive",
					"requiresDeactivated": true,
					"steps": [
						{ "type": "delay", "seconds": 5 },
						{ "type": "notify", "text": "{name} has been successfully revived!" },
						{ "type": "action", "action": "reactivate" },
						{ "type": "open_menu", "menu": "diagnostic_menu" }
					]
				},
				{
					"caption": "Reset",
					"excludePlayerFaction": true,
					"excludeDeactivated": true,
					"steps": [
						{ "type": "delay", "seconds": 5 },
						{ "type": "show_text", "text": "{name} has been reset!", "color": "#3399FF" },
						{ "type": "action", "action": "join_squad" },
						{ "type": "action", "action": "system_reset" },
						{ "type": "open_menu", "menu": "diagnostic_menu" }
					]
				},
				{
					"caption": "Exit",
					"steps": []
				}
			]
		}
	}
}
