{
	"Plugins" : [ "SkeletonRebirthDiagnostics.dll" ],
	"DialogueBoxes" : {
		"system_menu": {
			"title": "System Menu",
			"message": "{name} is in a catastrophic shutdown loop. Insert a core to run system diagnostics.",
			"buttons": [
				{
					"caption": "Diagnostics",
					"excludeAnimal": true,
					"requiresSkill": "science",
					"minSkill": 1,
					"requiresItem": "43392-changes_otto.mod",
					"steps": [
						{ "type": "take_item", "item": "43392-changes_otto.mod" },
						{ "type": "show_text", "text": "AI Core inserted - running diagnostics...", "color": "#FF4C4C" },
						{ "type": "delay", "seconds": 3 },
						{ "type": "open_menu", "menu": "diagnostic_menu" }
					]
				},
				{
					"caption": "Diagnostics",
					"requiresAnimal": true,
					"requiresSkill": "science",
					"minSkill": 1,
					"requiresItem": "43398-changes_otto.mod",
					"steps": [
						{ "type": "take_item", "item": "43398-changes_otto.mod" },
						{ "type": "show_text", "text": "Power Core inserted - running diagnostics...", "color": "#FF4C4C" },
						{ "type": "delay", "seconds": 3 },
						{ "type": "open_menu", "menu": "diagnostic_menu" }
					]
				},
				{
					"caption": "Do nothing",
					"steps": []
				}
			]
		},

		"diagnostic_menu": {
			"title": "Diagnostics",
			"message": "Diagnostics complete. {name}'s core systems are accessible. Select a course of action.",
			"buttons": [
				{
					"caption": "Revive",
					"requiresDeactivated": true,
					"steps": [
						{ "type": "delay", "seconds": 5 },
						{ "type": "show_text", "text": "{name} has been successfully revived!", "color": "#3399FF" },
						{ "type": "action", "action": "reactivate" },
						{ "type": "open_menu", "menu": "diagnostic_menu" }
					]
				},
				{
					"caption": "Reset",
					"excludePlayerFaction": true,
					"steps": [
						{ "type": "delay", "seconds": 5 },
						{ "type": "show_text", "text": "{name} has been reset!", "color": "#3399FF" },
						{ "type": "action", "action": "join_squad" },
						{ "type": "action", "action": "system_reset" },
						{ "type": "open_menu", "menu": "diagnostic_menu" }
					]
				},
				{
					"caption": "Exit",
					"steps": []
				}
			]
		}
	}
}
